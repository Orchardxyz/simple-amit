{
  "name": "simple-amit",
  "displayName": "simple-amit",
  "description": "Simple extension for generating commit message with AI.",
  "version": "0.1.1",
  "publisher": "Orchard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Orchardxyz/simple-amit.git"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "icon": "resources/brand/simple-amit-mark.png",
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "simple-amit.openSettings",
        "category": "Simple Amit",
        "title": "Open Settings"
      },
      {
        "command": "simple-amit.generateCommitMessage",
        "category": "Simple Amit",
        "title": "Generate Commit Message",
        "icon": {
          "light": "resources/icons/simple-amit-light.svg",
          "dark": "resources/icons/simple-amit-dark.svg"
        }
      }
    ],
    "submenus": [
      {
        "id": "simple-amit.scmMenu",
        "label": "Simple Amit"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "simple-amit.generateCommitMessage",
          "when": "scmProvider == git",
          "group": "navigation@1"
        },
        {
          "submenu": "simple-amit.scmMenu",
          "when": "scmProvider == git",
          "group": "simpleAmit@1"
        }
      ],
      "simple-amit.scmMenu": [
        {
          "command": "simple-amit.generateCommitMessage",
          "group": "simpleAmit@1"
        },
        {
          "command": "simple-amit.openSettings",
          "group": "simpleAmit@2"
        }
      ]
    },
    "configuration": {
      "title": "Simple Amit",
      "properties": {
        "simple-amit.providerType": {
          "type": "string",
          "enum": [
            "anthropic",
            "gemini",
            "compatible"
          ],
          "default": "compatible",
          "description": "AI provider family used to generate commit messages."
        },
        "simple-amit.compatibleProviderId": {
          "type": "string",
          "default": "openai",
          "description": "Provider id from the OpenAI-compatible provider registry."
        },
        "simple-amit.baseUrl": {
          "type": "string",
          "default": "https://api.openai.com",
          "description": "Base URL for OpenAI-compatible provider requests."
        },
        "simple-amit.models": {
          "type": "object",
          "default": {
            "anthropic": "",
            "gemini": "",
            "compatible": {}
          },
          "properties": {
            "anthropic": {
              "type": "string",
              "default": "",
              "description": "Model id used for Anthropic."
            },
            "gemini": {
              "type": "string",
              "default": "",
              "description": "Model id used for Gemini."
            },
            "compatible": {
              "type": "object",
              "default": {},
              "additionalProperties": {
                "type": "string"
              },
              "description": "Model ids saved by OpenAI-compatible provider id."
            }
          },
          "description": "Model ids saved per provider."
        },
        "simple-amit.language": {
          "type": "string",
          "enum": [
            "zh-CN",
            "en"
          ],
          "default": "en",
          "description": "Language used for generated commit messages."
        },
        "simple-amit.instructions": {
          "type": "string",
          "default": "Analyze the workspace changes as the source of truth. Learn the repository's commit-message format from recent Git history, including its language, type, scope, and tone. If history is insufficient or inconsistent, use Conventional Commits: type(scope): short subject. Choose a type that reflects the change; use style for visual-only changes. Return only one commit message in the selected language.",
          "description": "Instructions appended to commit-message generation requests."
        }
      }
    }
  },
  "scripts": {
    "prepare": "husky && skills-npm",
    "vscode:prepublish": "pnpm run package",
    "ci": "pnpm run format:check && pnpm run check-types && pnpm run lint",
    "compile": "pnpm run format:check && pnpm run check-types && pnpm run lint && pnpm run build:webview && pnpm run build:extension",
    "watch": "npm-run-all -p watch:*",
    "watch:extension": "node esbuild.js --watch",
    "watch:webview": "vite build --watch --config vite.webview.config.ts",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "build:extension": "node esbuild.js",
    "build:webview": "vite build --config vite.webview.config.ts",
    "package": "pnpm run format:check && pnpm run check-types && pnpm run lint && pnpm run build:webview && node esbuild.js --production",
    "compile-tests": "tsc -p tsconfig.test.json",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check:extension": "tsc --noEmit --project tsconfig.extension.json",
    "check:webview": "svelte-check --tsconfig ./tsconfig.webview.json",
    "check-types": "pnpm run check:extension && pnpm run check:webview",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vscode-test",
    "test:ci": "xvfb-run -a pnpm test",
    "vsix:pre": "mkdir -p dist-vsix && vsce package --pre-release --no-dependencies --out dist-vsix/simple-amit-${npm_package_version}-pre.vsix",
    "vsix:stable": "mkdir -p dist-vsix && vsce package --no-dependencies --out dist-vsix/simple-amit-${npm_package_version}.vsix",
    "publish:vscode:pre": "vsce publish --pre-release --packagePath dist-vsix/simple-amit-${npm_package_version}-pre.vsix",
    "publish:vscode": "vsce publish --packagePath dist-vsix/simple-amit-${npm_package_version}.vsix",
    "publish:openvsx": "ovsx publish dist-vsix/simple-amit-${npm_package_version}.vsix --pat $OVSX_PAT"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@lucide/svelte": "^1.24.0",
    "@oryz/eslint-config": "^2.2.1",
    "@oryz/prettier-config": "^1.0.0",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.101.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "bits-ui": "^2.18.1",
    "csstype": "^3.2.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-svelte": "^3.20.0",
    "husky": "^9.1.7",
    "npm-run-all": "^4.1.5",
    "ovsx": "^1.0.2",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "skills-npm": "^1.2.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "svelte-eslint-parser": "^1.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.97",
    "@ai-sdk/google": "^3.0.94",
    "@ai-sdk/openai-compatible": "^2.0.61",
    "@ai-sdk/provider": "^3.0.14",
    "@ai-sdk/provider-utils": "^4.0.40",
    "@voltagent/core": "^2.9.0",
    "ai": "^6.0.230",
    "openai-compatible-provider-registry": "0.1.0-beta.0",
    "simple-git": "^3.36.0",
    "svelte-sonner": "^1.1.1",
    "zod": "^4.4.3"
  }
}
