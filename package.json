{
  "name": "simple-amit",
  "displayName": "simple-amit",
  "description": "Simple extension for generating commit message with AI.",
  "version": "0.0.1",
  "license": "MIT",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "simple-amit.openSettings",
        "title": "Simple Amit: Open Webview"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && pnpm run build:webview && pnpm run build:extension",
    "watch": "npm-run-all -p watch:*",
    "watch:extension": "node esbuild.js --watch",
    "watch:webview": "vite build --watch --config vite.webview.config.ts",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "build:extension": "node esbuild.js",
    "build:webview": "vite build --config vite.webview.config.ts",
    "package": "pnpm run check-types && pnpm run lint && pnpm run build:webview && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check:extension": "tsc --noEmit",
    "check:webview": "svelte-check --tsconfig ./tsconfig.json",
    "check-types": "pnpm run check:extension && pnpm run check:webview",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@oryz/eslint-config": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.101.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-svelte": "^3.20.0",
    "npm-run-all": "^4.1.5",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "svelte-eslint-parser": "^1.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.12",
    "@ai-sdk/google": "^4.0.12",
    "@ai-sdk/openai-compatible": "^3.0.7",
    "ai": "^7.0.22",
    "openai-compatible-provider-registry": "0.1.0-beta.0",
    "simple-git": "^3.36.0"
  }
}
